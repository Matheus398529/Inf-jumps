    return parts
end

local function CreateSelectionBoxFor(obj)
    local parts=GetAllBaseParts(obj)
    for _,part in ipairs(parts) do
        local sb=Instance.new("SelectionBox")
        sb.Color3=Color3.fromRGB(88,166,255);sb.LineThickness=0.06
        sb.SurfaceColor3=Color3.fromRGB(88,166,255);sb.SurfaceTransparency=0.85
        sb.Adornee=part;sb.Parent=SelectionFolder
