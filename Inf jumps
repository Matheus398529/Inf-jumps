local function CheckKey(key)
    key = key:match("^%s*(.-)%s*$")
    local myNick = game:GetService("Players").LocalPlayer.Name
    local owner = KEY_MAP[key]
    if not owner then return false end
    if owner == myNick then return true end
    return false, "key_wrong_user"
end

