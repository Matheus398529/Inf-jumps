        task.spawn(function()
            local t=0
            while sb and sb.Parent do
                t=t+0.05;sb.SurfaceTransparency=0.5+0.35*math.sin(t*4);task.wait(0.03)
            end
        end)
    end
end

local ClickDownPos=nil
UserInputService.InputBegan:Connect(function(input,gp)
    if gp then return end
    if input.UserInputType==Enum.UserInputType.MouseButton1 then
        ClickDownPos=Vector2.new(input.Position.X,input.Position.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input,gp)
    if gp then return end
    if input.UserInputType~=Enum.UserInputType.MouseButton1 then return end
    if not ClickDownPos then return end
    local upPos=Vector2.new(input.Position.X,input.Position.Y)
    local dist=(upPos-ClickDownPos).Magnitude
    ClickDownPos=nil
    if dist>6 then return end
    local guiObjs=LocalPlayer.PlayerGui:GetGuiObjectsAtPosition(input.Position.X,input.Position.Y)
    for _,g in ipairs(guiObjs) do
        if g.Name=="MoonCopyLitePro" or g:IsDescendantOf(game:GetService("CoreGui")) then return end
    end
    if PlacementActive then return end
    local unitRay=Camera:ScreenPointToRay(input.Position.X,input.Position.Y)
    local rayParams=RaycastParams.new()
    rayParams.FilterType=Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances={LocalPlayer.Character or Instance.new("Model"),SelectionFolder}
    local result=workspace:Raycast(unitRay.Origin,unitRay.Direction*500,rayParams)
    if result and result.Instance then
        local target=GetSelectTarget(result.Instance)
        if not target then ClearSelection();return end
        local shift=UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or UserInputService:IsKeyDown(Enum.KeyCode.RightShift)
        if not shift then ClearSelection() end
        local alreadyIdx=nil
        for i,o in ipairs(SelectedObjects) do if o==target then alreadyIdx=i;break end end
        if alreadyIdx then
            table.remove(SelectedObjects,alreadyIdx)
            for _,sb in pairs(SelectionBoxes) do pcall(function() sb:Destroy() end) end
            SelectionBoxes={}
            for _,o in ipairs(SelectedObjects) do CreateSelectionBoxFor(o) end
        else
            table.insert(SelectedObjects,target);CreateSelectionBoxFor(target)
        end
        pcall(function() Selection:Set(SelectedObjects) end)
        SetLastAction("Sel: "..target.Name.." ("..#SelectedObjects..")")
    else
        ClearSelection();SetLastAction("Seleção limpa.")
    end
end)

