local function StartPlacement(saveName,jsonStr,scale,onConfirmed)
    CancelPlacement();PlacementActive=true;OnPlacementConfirmed=onConfirmed;PlacementRotY=0;PlacementScale=scale or 1
    local data=SafeJSON(jsonStr);if not data then if onConfirmed then onConfirmed(nil,nil,0,1) end;return end
    PlacementData={saveName=saveName,data=data,jsonStr=jsonStr}
    BuildGhosts(data,0,PlacementScale);ShowPlacementHint(saveName)
    PlacementConnection=RunService.RenderStepped:Connect(function()
        if not PlacementActive or not PlacementFolder then return end
        local unitRay=Camera:ScreenPointToRay(Mouse.X,Mouse.Y)
        local rayParams=RaycastParams.new();rayParams.FilterType=Enum.RaycastFilterType.Exclude
        rayParams.FilterDescendantsInstances={LocalPlayer.Character or Instance.new("Model"),PlacementFolder}
        local result=workspace:Raycast(unitRay.Origin,unitRay.Direction*1000,rayParams)
        if result then LastMousePos=result.Position;MoveGhosts(result.Position) end
    end)
    PlacementClickConn=Mouse.Button1Down:Connect(function()
        if not PlacementActive or not PlacementFolder then return end
        for _,g in ipairs(PlacementGhosts) do if type(g)=="table" and g.part then TweenService:Create(g.part,TweenInfo.new(0.15),{Color=Color3.fromRGB(255,255,255),Transparency=0.1}):Play() end end
        local pos=LastMousePos;local rotY=PlacementRotY;local sc=PlacementScale
        local js=PlacementData and PlacementData.jsonStr or nil;local cb=OnPlacementConfirmed
        task.delay(0.2,function() CancelPlacement() end);if cb and js then cb(js,pos,rotY,sc) end
    end)
    PlacementKeyConn=UserInputService.InputBegan:Connect(function(input,gp)
        if gp then return end
        if input.KeyCode==Enum.KeyCode.Escape then CancelPlacement()
        elseif input.KeyCode==Enum.KeyCode.Q then PlacementRotY=PlacementRotY+45;if PlacementData then BuildGhosts(PlacementData.data,PlacementRotY,PlacementScale);MoveGhosts(LastMousePos) end
        elseif input.KeyCode==Enum.KeyCode.E then PlacementRotY=PlacementRotY-45;if PlacementData then BuildGhosts(PlacementData.data,PlacementRotY,PlacementScale);MoveGhosts(LastMousePos) end
        end
    end)
end

