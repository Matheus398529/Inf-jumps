local SelectedObjects = {}
local SelectionBoxes  = {}
local SelectionFolder = Instance.new("Folder")
SelectionFolder.Name  = "_MCLSelBoxes"
SelectionFolder.Parent= workspace

local function ClearSelection()
    for _,sb in pairs(SelectionBoxes) do pcall(function() sb:Destroy() end) end
    SelectionBoxes={}
    SelectedObjects={}
    pcall(function() Selection:Set({}) end)
end

local function GetSelectTarget(obj)
    -- se obj está dentro de um Model, seleciona o Model inteiro
    local cur=obj
    while cur and cur.Parent do
        if cur.Parent==workspace then return cur end
        cur=cur.Parent
    end
    return obj
end

local function GetAllBaseParts(obj)
    local parts={}
    if obj:IsA("BasePart") then table.insert(parts,obj) end
    for _,d in ipairs(obj:GetDescendants()) do
        if d:IsA("BasePart") then table.insert(parts,d) end
    end
    return parts
end

local function CreateSelectionBoxFor(obj)
    local parts=GetAllBaseParts(obj)
    for _,part in ipairs(parts) do
        local sb=Instance.new("SelectionBox")
        sb.Color3=Color3.fromRGB(88,166,255)
        sb.LineThickness=0.06
        sb.SurfaceColor3=Color3.fromRGB(88,166,255)
        sb.SurfaceTransparency=0.85
        sb.Adornee=part
        sb.Parent=SelectionFolder
        table.insert(SelectionBoxes,sb)
        -- brilho pulsante
        task.spawn(function()
            local t=0
            while sb and sb.Parent do
                t=t+0.05
                local alpha=0.5+0.35*math.sin(t*4)
                sb.SurfaceTransparency=alpha
                task.wait(0.03)
            end
        end)
    end
end

local SelectionEnabled = true
local ClickDownPos     = nil

-- detecta click (mouse down + up no mesmo lugar = clique, não arraste)
UserInputService.InputBegan:Connect(function(input,gp)
    if gp then return end
    if input.UserInputType==Enum.UserInputType.MouseButton1 then
        ClickDownPos=Vector2.new(input.Position.X,input.Position.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input,gp)
    if gp then return end
    if input.UserInputType~=Enum.UserInputType.MouseButton1 then return end
    if not SelectionEnabled then return end
    if PlacementActive then return end
    if not ClickDownPos then return end

    local upPos=Vector2.new(input.Position.X,input.Position.Y)
    local dist=(upPos-ClickDownPos).Magnitude
    ClickDownPos=nil

    -- só processa se não arrastou (tolerância de 6px)
    if dist>6 then return end

    -- ignora se clicou na GUI
    local guiObjs=LocalPlayer.PlayerGui:GetGuiObjectsAtPosition(input.Position.X,input.Position.Y)
    for _,g in ipairs(guiObjs) do
        if g:IsDescendantOf(Root) then return end
    end

    -- raycast
    local unitRay=Camera:ScreenPointToRay(input.Position.X,input.Position.Y)
    local rayParams=RaycastParams.new()
    rayParams.FilterType=Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances={
        LocalPlayer.Character or Instance.new("Model"),
        SelectionFolder,
        PlacementFolder or Instance.new("Model"),
    }
    local result=workspace:Raycast(unitRay.Origin,unitRay.Direction*500,rayParams)

    if result and result.Instance then
        local target=GetSelectTarget(result.Instance)
        if not target then ClearSelection();return end

        -- Shift = adiciona à seleção, sem shift = limpa e seleciona novo
        local shift=UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or
                    UserInputService:IsKeyDown(Enum.KeyCode.RightShift)

        if not shift then ClearSelection() end

        -- verifica se já está selecionado (toggle)
        local alreadyIdx=nil
        for i,o in ipairs(SelectedObjects) do if o==target then alreadyIdx=i;break end end

        if alreadyIdx then
            -- deseleciona
            table.remove(SelectedObjects,alreadyIdx)
            -- recria boxes
            for _,sb in pairs(SelectionBoxes) do pcall(function() sb:Destroy() end) end
            SelectionBoxes={}
            for _,o in ipairs(SelectedObjects) do CreateSelectionBoxFor(o) end
        else
            table.insert(SelectedObjects,target)
            CreateSelectionBoxFor(target)
        end

        -- sincroniza Selection service
        pcall(function() Selection:Set(SelectedObjects) end)

        -- atualiza modo de cópia na aba Copiar automaticamente para "selection"
        SetLastAction("Selecionado: "..target.Name.." ("..#SelectedObjects.." obj)")
    else
        -- clicou no vazio = limpa
        ClearSelection()
        SetLastAction("Seleção limpa.")
    end
end)

