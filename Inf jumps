-- Nome do hub
game:GetService("Players").PlayerAdded:Connect(function(player)
    -- Definir o nome do jogador como "JK Hub" quando ele entrar
    player.DisplayName = "JK Hub"
end)

-- Pulo infinito
local player = game.Players.LocalPlayer

-- Espera até o personagem do jogador ser carregado
player.CharacterAdded:Wait()

local humanoid = player.Character:WaitForChild("Humanoid")

-- Loop de pulo infinito
while true do
    -- Alterando o estado para poder pular continuamente
    humanoid:ChangeState(Enum.HumanoidStateType.Physics)
    humanoid.PlatformStand = true
    humanoid:Move(Vector3.new(0, 100, 0))  -- Ajuste o valor para definir a altura do pulo

    wait(0.1)  -- Ajuste o tempo de espera entre cada pulo (quanto menor, mais rápido o pulo)
end
