end

local function LoadKeyLocal()
    if not isfile(CONFIG.KEY_FILE) then return nil end
    local ok,k=pcall(readfile,CONFIG.KEY_FILE)
    return ok and k:match("^%s*(.-)%s*$") or nil
end

local function OpSave(name,json,itemCount,mode,password,tag,folder)
    local index=LoadIndex()
    for _,e in ipairs(index) do if e.name==name then return false,"Nome já existe!" end end
    if #index>=MaxSaves() then
        return false,IsPro() and "Limite atingido" or "Limite de "..CONFIG.FREE_MAX_SAVES.." saves!\n⭐ Ative o Pro para ilimitados."
    end
    local path=FOLDER.."/"..name..".json"
    local ok=pcall(writefile,path,json)
    if not ok then return false,"Erro ao gravar!" end
    table.insert(index,1,{
        name=name,itemCount=itemCount,time=os.time(),mode=mode,size=#json,
        hasPassword=(password and password~="") and true or false,
        tag=tag or nil,folder=folder or nil,favorite=false,
    })
    SaveIndex(index)
    return true
end

local function OpLoad(name)
    local path=FOLDER.."/"..name..".json"
    if not isfile(path) then
        local index=LoadIndex()
        for i,e in ipairs(index) do if e.name==name then table.remove(index,i);break end end
        SaveIndex(index)
        return false,"Arquivo não encontrado!"
    end
    local ok,json=pcall(readfile,path)
    if not ok or not json or json=="" then return false,"Arquivo corrompido!" end
    return true,json
end

local function OpDelete(name)
    pcall(delfile,FOLDER.."/"..name..".json")
    local index=LoadIndex()
    for i,e in ipairs(index) do if e.name==name then table.remove(index,i);break end end
    SaveIndex(index)
end

local function OpRename(oldName,newName)
    if oldName==newName then return false,"Nome igual!" end
    newName=newName:gsub('[/\\:*?"<>|]','_')
    local index=LoadIndex()
    for _,e in ipairs(index) do if e.name==newName then return false,"Nome já existe!" end end
    local oldPath=FOLDER.."/"..oldName..".json"
    local newPath=FOLDER.."/"..newName..".json"
    if not isfile(oldPath) then return false,"Save não encontrado!" end
    local ok,json=pcall(readfile,oldPath)
    if not ok then return false,"Erro ao ler!" end
    pcall(writefile,newPath,json);pcall(delfile,oldPath)
    for _,e in ipairs(index) do if e.name==oldName then e.name=newName;break end end
    SaveIndex(index)
    return true
end

local function OpDuplicate(name)
    local ok,json=OpLoad(name)
    if not ok then return false,json end
    local newName=name.."_copy";local counter=1
    local index=LoadIndex();local exists={}
    for _,e in ipairs(index) do exists[e.name]=true end
    while exists[newName] do counter=counter+1;newName=name.."_copy"..counter end
    local dok,data=pcall(function() return HttpService:JSONDecode(json) end)
    local itemCount=dok and #(data.Items or {}) or 0
    return OpSave(newName,json,itemCount,"workspace")
end

local function OpToggleFavorite(name)
    local index=LoadIndex()
    for _,e in ipairs(index) do if e.name==name then e.favorite=not e.favorite;break end end
