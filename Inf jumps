local function BuildGhosts(data,rotY,scale)
    if PlacementFolder then PlacementFolder:Destroy() end
    PlacementFolder=Instance.new("Model");PlacementFolder.Name="_MCLGhost";PlacementFolder.Parent=workspace
    PlacementGhosts={}
    local allParts={};for _,item in ipairs(data.Items or {}) do CollectBaseParts(item,allParts) end
    local sc=scale or 1;local minY=math.huge;local sumX,sumZ=0,0
    for _,part in ipairs(allParts) do
        local cf=dCF(part.Props.CFrame);local halfY=(part.Props.Size and part.Props.Size[2] or 1)*sc/2
        if cf.Position.Y*sc-halfY<minY then minY=cf.Position.Y*sc-halfY end
        sumX=sumX+cf.Position.X*sc;sumZ=sumZ+cf.Position.Z*sc
    end
    local cx=#allParts>0 and sumX/#allParts or 0;local cz=#allParts>0 and sumZ/#allParts or 0
    local rotCF=CFrame.Angles(0,math.rad(rotY),0)
    for _,part in ipairs(allParts) do
        local cf=dCF(part.Props.CFrame)
        local color=part.Props.Color and dC3(part.Props.Color) or Color3.fromRGB(200,200,200)
        local size=part.Props.Size and Vector3.new(part.Props.Size[1]*sc,part.Props.Size[2]*sc,part.Props.Size[3]*sc) or Vector3.new(1,1,1)
        local relPos=Vector3.new(cf.Position.X*sc-cx,cf.Position.Y*sc-minY,cf.Position.Z*sc-cz)
        local relCF=CFrame.new(relPos)*(cf-cf.Position);local rotatedPos=rotCF*relCF.Position
        local finalRelCF=CFrame.new(rotatedPos)*(rotCF*(cf-cf.Position))
        local ghost=Instance.new("Part");ghost.Name="_ghost";ghost.Size=size;ghost.Anchored=true
        ghost.CanCollide=false;ghost.CanTouch=false;ghost.CastShadow=false
        ghost.Material=Enum.Material.SmoothPlastic;ghost.Color=color;ghost.Transparency=0.45
        ghost.CFrame=finalRelCF;ghost.Parent=PlacementFolder
        local sel=Instance.new("SelectionBox");sel.Color3=Color3.fromRGB(255,255,255);sel.LineThickness=0.03;sel.SurfaceTransparency=1;sel.Adornee=ghost;sel.Parent=ghost
        table.insert(PlacementGhosts,{part=ghost,relCF=finalRelCF})
    end
    local cp=Instance.new("Part");cp.Name="_center";cp.Size=Vector3.new(0.1,0.1,0.1);cp.Anchored=true;cp.CanCollide=false;cp.Transparency=1;cp.Parent=PlacementFolder
    local bb=Instance.new("BillboardGui");bb.Size=UDim2.new(0,220,0,50);bb.StudsOffset=Vector3.new(0,5,0);bb.AlwaysOnTop=true;bb.Parent=cp
    local bbl=Instance.new("TextLabel");bbl.BackgroundTransparency=1;bbl.Size=UDim2.new(1,0,0.5,0)
    bbl.Text="📍 "..(PlacementData and PlacementData.saveName or "").."  ["..string.format("%.2f",sc).."x]"
    bbl.TextColor3=Color3.fromRGB(255,255,255);bbl.TextSize=12;bbl.Font=Enum.Font.GothamBold;bbl.TextXAlignment=Enum.TextXAlignment.Center;bbl.TextStrokeTransparency=0;bbl.TextStrokeColor3=Color3.fromRGB(0,0,0);bbl.Parent=bb
    local rl=Instance.new("TextLabel");rl.BackgroundTransparency=1;rl.Size=UDim2.new(1,0,0.5,0);rl.Position=UDim2.new(0,0,0.5,0)
    rl.Text="Q/E = Rotacionar ("..rotY.."°)  •  Click = Confirmar"
    rl.TextColor3=Color3.fromRGB(180,200,255);rl.TextSize=9;rl.Font=Enum.Font.Gotham;rl.TextXAlignment=Enum.TextXAlignment.Center;rl.TextStrokeTransparency=0;rl.TextStrokeColor3=Color3.fromRGB(0,0,0);rl.Parent=bb
    PlacementGhosts.centerPart=cp
end

