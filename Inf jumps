local function RsInst(d,parent,offset,scale)
    local ok,inst=pcall(function() return Instance.new(d.ClassName) end)
    if not ok then return end
    inst.Name=d.Name
    pcall(function()
        local p=d.Props or {}
        if inst:IsA("BasePart") then
            local sc=scale or 1
            if p.Size   then inst.Size=Vector3.new(p.Size[1]*sc,p.Size[2]*sc,p.Size[3]*sc) end
            if p.CFrame then
                local cf=dCF(p.CFrame)
                if sc~=1 then cf=CFrame.new(cf.Position*sc)*(cf-cf.Position) end
                if offset then cf=CFrame.new(cf.Position+offset)*(cf-cf.Position) end
                inst.CFrame=cf
            end
            if p.Color  then inst.Color=dC3(p.Color) end
            if p.Material then pcall(function() inst.Material=Enum.Material[p.Material] end) end
            if p.Transparency~=nil then inst.Transparency=p.Transparency end
            inst.Anchored=true
            inst.CanCollide=p.CanCollide~=nil and p.CanCollide or true
            if p.CastShadow~=nil then inst.CastShadow=p.CastShadow end
            if p.Locked~=nil then inst.Locked=p.Locked end
        end
        if inst:IsA("MeshPart") then
            if p.MeshId    then pcall(function() inst.MeshId=p.MeshId end) end
            if p.TextureID then pcall(function() inst.TextureID=p.TextureID end) end
        end
        if p.Source~=nil   then pcall(function() inst.Source=p.Source end) end
        if p.Disabled~=nil then pcall(function() inst.Disabled=p.Disabled end) end
        if p.Value~=nil    then pcall(function() inst.Value=p.Value end) end
    end)
    for _,ch in ipairs(d.Children or {}) do RsInst(ch,inst,nil,scale) end
    inst.Parent=parent
    return inst
end

local function CollectBaseParts(item,result)
    result=result or {}
    if item.Props and item.Props.CFrame then table.insert(result,item) end
    for _,child in ipairs(item.Children or {}) do CollectBaseParts(child,result) end
    return result
end

local function LoadJSONAdvanced(json,clearFirst,targetPos,rotY,scale,onDone)
    if clearFirst then
        for _,o in ipairs(workspace:GetChildren()) do
            if o~=workspace.Terrain and o.ClassName~="Camera" then pcall(function() o:Destroy() end) end
        end
    end
    local ok,data=pcall(function() return HttpService:JSONDecode(json) end)
    if not ok then if onDone then onDone(false,"JSON inválido") end;return end
    local sc=scale or 1
    local offset=nil
    if targetPos then
        local allParts={}
        for _,item in ipairs(data.Items or {}) do CollectBaseParts(item,allParts) end
        if #allParts>0 then
            local minY=math.huge;local sumX,sumZ=0,0
            for _,part in ipairs(allParts) do
                local cf=dCF(part.Props.CFrame)
                local halfY=(part.Props.Size and part.Props.Size[2] or 1)*sc/2
                if cf.Position.Y*sc-halfY<minY then minY=cf.Position.Y*sc-halfY end
                sumX=sumX+cf.Position.X*sc;sumZ=sumZ+cf.Position.Z*sc
            end
            offset=Vector3.new(targetPos.X-sumX/#allParts,targetPos.Y-minY,targetPos.Z-sumZ/#allParts)
        end
    end
    if rotY and rotY~=0 then
        local rotCF=CFrame.Angles(0,math.rad(rotY),0)
        local allParts2={}
        for _,item in ipairs(data.Items or {}) do CollectBaseParts(item,allParts2) end
        local sumX2,sumZ2=0,0
        for _,p2 in ipairs(allParts2) do local cf2=dCF(p2.Props.CFrame);sumX2=sumX2+cf2.Position.X;sumZ2=sumZ2+cf2.Position.Z end
        local cx2=#allParts2>0 and sumX2/#allParts2 or 0
        local cz2=#allParts2>0 and sumZ2/#allParts2 or 0
        local function applyRot(item)
            if item.Props and item.Props.CFrame then
                local cf=dCF(item.Props.CFrame)
                local relPos=Vector3.new(cf.Position.X-cx2,0,cf.Position.Z-cz2)
                local rotated=rotCF*relPos
                item.Props.CFrame=sCF(CFrame.new(cx2+rotated.X,cf.Position.Y,cz2+rotated.Z)*(rotCF*(cf-cf.Position)))
            end
            for _,ch in ipairs(item.Children or {}) do applyRot(ch) end
        end
        for _,item in ipairs(data.Items or {}) do applyRot(item) end
    end
    local items=data.Items or {};local total=#items;local count=0
    local saveName=(LoadJSONAdvanced_SaveName or "")
    local targetParent=workspace
    if saveName~="" then
        local folderName="WorkspaceCopied("..saveName..")"
        local folder=workspace:FindFirstChild(folderName)
        if not folder then folder=Instance.new("Folder");folder.Name=folderName;folder.Parent=workspace end
        targetParent=folder
    end
    local function processNext(i)
        if i>total then if onDone then onDone(true,count) end;return end
        local bend=math.min(i+BATCH_SIZE-1,total)
        for j=i,bend do RsInst(items[j],targetParent,offset,sc);count=count+1 end
        task.wait();processNext(bend+1)
    end
    task.spawn(function() processNext(1) end)
end

local function SpawnGrid(json,centerPos,rotY,scale,cols,rows,spacing,onDone)
    local ok,data=pcall(function() return HttpService:JSONDecode(json) end)
    if not ok then if onDone then onDone(false,0) end;return end
    local allParts={}
    for _,item in ipairs(data.Items or {}) do CollectBaseParts(item,allParts) end
    local sc=scale or 1
    local minX,maxX,minZ,maxZ=math.huge,-math.huge,math.huge,-math.huge
    for _,part in ipairs(allParts) do
        local cf=dCF(part.Props.CFrame)
        local sx=(part.Props.Size and part.Props.Size[1] or 1)*sc/2
        local sz=(part.Props.Size and part.Props.Size[3] or 1)*sc/2
        if cf.Position.X-sx<minX then minX=cf.Position.X-sx end
        if cf.Position.X+sx>maxX then maxX=cf.Position.X+sx end
        if cf.Position.Z-sz<minZ then minZ=cf.Position.Z-sz end
        if cf.Position.Z+sz>maxZ then maxZ=cf.Position.Z+sz end
    end
    local bw=math.max((maxX-minX)*sc,1)+spacing
    local bd=math.max((maxZ-minZ)*sc,1)+spacing
    local totalCount=0
    local function spawnOne(col,row)
        local ox=(col-(cols-1)/2)*bw
        local oz=(row-(rows-1)/2)*bd
        local pos=Vector3.new(centerPos.X+ox,centerPos.Y,centerPos.Z+oz)
        local jok,dataCopy=pcall(function() return HttpService:JSONDecode(json) end)
        if not jok then return end
        local parts2={}
        for _,item in ipairs(dataCopy.Items or {}) do CollectBaseParts(item,parts2) end
        local offset2=nil
        if #parts2>0 then
            local minY2=math.huge;local sumX2,sumZ2=0,0
            for _,part in ipairs(parts2) do
                local cf=dCF(part.Props.CFrame)
                local halfY=(part.Props.Size and part.Props.Size[2] or 1)*sc/2
                if cf.Position.Y*sc-halfY<minY2 then minY2=cf.Position.Y*sc-halfY end
                sumX2=sumX2+cf.Position.X*sc;sumZ2=sumZ2+cf.Position.Z*sc
            end
            offset2=Vector3.new(pos.X-sumX2/#parts2,pos.Y-minY2,pos.Z-sumZ2/#parts2)
        end
        if rotY and rotY~=0 then
            local rotCF=CFrame.Angles(0,math.rad(rotY),0)
            local sumX3,sumZ3=0,0
            for _,p3 in ipairs(parts2) do local cf3=dCF(p3.Props.CFrame);sumX3=sumX3+cf3.Position.X;sumZ3=sumZ3+cf3.Position.Z end
            local cx3=#parts2>0 and sumX3/#parts2 or 0
            local cz3=#parts2>0 and sumZ3/#parts2 or 0
            local function applyRot2(item)
                if item.Props and item.Props.CFrame then
                    local cf=dCF(item.Props.CFrame)
                    local relPos=Vector3.new(cf.Position.X-cx3,0,cf.Position.Z-cz3)
                    local rotated=rotCF*relPos
                    item.Props.CFrame=sCF(CFrame.new(cx3+rotated.X,cf.Position.Y,cz3+rotated.Z)*(rotCF*(cf-cf.Position)))
                end
                for _,ch in ipairs(item.Children or {}) do applyRot2(ch) end
            end
            for _,item in ipairs(dataCopy.Items or {}) do applyRot2(item) end
        end
        for _,item in ipairs(dataCopy.Items or {}) do RsInst(item,workspace,offset2,sc);totalCount=totalCount+1 end
    end
    task.spawn(function()
        for row=0,rows-1 do
            for col=0,cols-1 do spawnOne(col,row);task.wait() end
        end
        if onDone then onDone(true,totalCount) end
    end)
end

