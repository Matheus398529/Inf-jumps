end

local function OpSetFolder(name,folderName)
    local index=LoadIndex()
    for _,e in ipairs(index) do
        if e.name==name then e.folder=(folderName and folderName~="") and folderName or nil;break end
    end
    SaveIndex(index)
end

local function SyncIndex()
    EnsureFolder()
    local index=LoadIndex();local synced={}
    for _,e in ipairs(index) do
        if isfile(FOLDER.."/"..e.name..".json") then table.insert(synced,e) end
    end
    local ok,files=pcall(listfiles,FOLDER)
    if ok then
        local indexed={}
        for _,e in ipairs(synced) do indexed[e.name]=true end
        for _,f in ipairs(files) do
            local fname=f:match("([^/\\]+)%.json$")
            if fname and fname~="index" and fname~="history" and fname~="folders" and not indexed[fname] then
                local jok,json=pcall(readfile,f)
                if jok and json and json~="" then
                    local dok,data=pcall(function() return HttpService:JSONDecode(json) end)
                    table.insert(synced,{name=fname,itemCount=dok and #(data.Items or {}) or 0,time=dok and (data.Time or 0) or 0,mode="workspace",size=#json})
                end
            end
        end
    end
    SaveIndex(synced)
    return synced
end

local function SaveBackup(label)
    local fname=BACKUP_FOLDER.."/backup_"..os.time()..".json"
    pcall(writefile,fname,HttpService:JSONEncode({Time=os.time(),Label=label}))
    local ok2,files2=pcall(listfiles,BACKUP_FOLDER)
    if ok2 then
        local bfiles={}
        for _,f in ipairs(files2) do if f:match("backup_%d+%.json$") then table.insert(bfiles,f) end end
        table.sort(bfiles)
        while #bfiles>5 do pcall(delfile,bfiles[1]);table.remove(bfiles,1) end
    end
end

