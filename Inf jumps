local function LoadLogs()
    if not isfile(LOGS_FILE) then return {} end
    local ok,d = pcall(function() return HttpService:JSONDecode(readfile(LOGS_FILE)) end)
    return (ok and type(d)=="table") and d or {}
end
local function SaveLogs(t) EnsureFolder(); pcall(writefile,LOGS_FILE,HttpService:JSONEncode(t)) end
local function LoadBlocked()
    if not isfile(BLOCKED_FILE) then return {} end
    local ok,d = pcall(function() return HttpService:JSONDecode(readfile(BLOCKED_FILE)) end)
    return (ok and type(d)=="table") and d or {}
end
local function SaveBlocked(t) EnsureFolder(); pcall(writefile,BLOCKED_FILE,HttpService:JSONEncode(t)) end
local function IsKeyBlocked(key)
    for _,k in ipairs(LoadBlocked()) do if k==key then return true end end
    return false
end
local function BlockKey(key)
    local b=LoadBlocked()
    for _,k in ipairs(b) do if k==key then return end end
    table.insert(b,key); SaveBlocked(b)
end
local function UnblockKey(key)
    local b=LoadBlocked()
    for i,k in ipairs(b) do if k==key then table.remove(b,i);break end end
    SaveBlocked(b)
end
local function RegisterLog(nick,key)
    local utc=os.time(); local brt=utc-(3*3600); local dt=os.date("*t",brt)
    local ts=string.format("%02d/%02d/%04d %02d:%02d",dt.day,dt.month,dt.year,dt.hour,dt.min)
    local logs=LoadLogs()
    for _,e in ipairs(logs) do if e.key==key and e.nick==nick and (utc-(e.utc or 0))<60 then return end end
    table.insert(logs,1,{nick=nick,key=key,time=ts,utc=utc})
    while #logs>200 do table.remove(logs,#logs) end
    SaveLogs(logs)
end

