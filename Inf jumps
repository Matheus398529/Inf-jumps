local function EnsureFolder()
    if not isfolder(FOLDER)        then makefolder(FOLDER)        end
    if not isfolder(BACKUP_FOLDER) then makefolder(BACKUP_FOLDER) end
end

local function LoadIndex()
    EnsureFolder()
    if not isfile(IDX_FILE) then return {} end
    local ok,data=pcall(function() return HttpService:JSONDecode(readfile(IDX_FILE)) end)
    if not ok or type(data)~="table" then return {} end
    return data
end

local function SaveIndex(index)
    EnsureFolder()
    pcall(writefile,IDX_FILE,HttpService:JSONEncode(index))
end

local function SaveKeyLocal(key)
