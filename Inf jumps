local function ExportCollection(saveNames)
    local collection = {
        version = "MCL_Collection_1.0",
        exportTime = os.time(),
        saves = {}
    }
    local index = LoadIndex()
    for _, name in ipairs(saveNames) do
        local ok, json = OpLoad(name)
        if ok then
            local meta = nil
            for _, e in ipairs(index) do
                if e.name == name then meta = e; break end
            end
            local dok, data = pcall(function() return HttpService:JSONDecode(json) end)
            if dok then
                table.insert(collection.saves, {
                    meta = meta,
                    data = data
                })
            end
        end
    end
    return HttpService:JSONEncode(collection)
end

local function ImportCollection(collectionJSON, onDone)
    local ok, collection = pcall(function()
        return HttpService:JSONDecode(collectionJSON)
    end)
    if not ok or type(collection) ~= "table" or collection.version ~= "MCL_Collection_1.0" then
        if onDone then onDone(false, "JSON inválido ou versão incompatível") end
        return
    end
    local imported = 0
    local skipped = 0
    local index = LoadIndex()
    local existing = {}
    for _, e in ipairs(index) do existing[e.name] = true end

    for _, entry in ipairs(collection.saves or {}) do
        local meta = entry.meta
        if meta and entry.data then
            local name = meta.name
            local finalName = name
            local counter = 1
            while existing[finalName] do
                finalName = name .. "_imp" .. counter
                counter = counter + 1
            end
            local entryJSON = HttpService:JSONEncode(entry.data)
            local saveOk, _ = OpSave(
                finalName,
                entryJSON,
                meta.itemCount or 0,
                meta.mode or "workspace",
                nil,
                meta.tag or nil,
                meta.folder or nil
            )
            if saveOk then
                existing[finalName] = true
                imported = imported + 1
            else
                skipped = skipped + 1
            end
        end
    end
    if onDone then onDone(true, imported, skipped) end
end

