local function LoadIndex()
    EnsureFolder()
    if not isfile(IDX_FILE) then return {} end
    local ok,d=pcall(function() return HttpService:JSONDecode(readfile(IDX_FILE)) end)
    if not ok or type(d)~="table" then return {} end
    return d
end
local function SaveIndex(t) EnsureFolder(); pcall(writefile,IDX_FILE,HttpService:JSONEncode(t)) end
local function SaveKeyLocal(key) EnsureFolder(); pcall(writefile,CONFIG.KEY_FILE,key) end
local function LoadKeyLocal()
    if not isfile(CONFIG.KEY_FILE) then return nil end
    local ok,k=pcall(readfile,CONFIG.KEY_FILE)
    return ok and k:match("^%s*(.-)%s*$") or nil
end
local function OpLoad(name)
    local path=FOLDER.."/"..name..".json"
    if not isfile(path) then
        local idx=LoadIndex()
        for i,e in ipairs(idx) do if e.name==name then table.remove(idx,i);break end end
        SaveIndex(idx); return false,"Arquivo não encontrado!"
    end
    local ok,json=pcall(readfile,path)
    if not ok or not json or json=="" then return false,"Arquivo corrompido!" end
    return true,json
end
local function OpDelete(name)
    pcall(delfile,FOLDER.."/"..name..".json")
    local idx=LoadIndex()
    for i,e in ipairs(idx) do if e.name==name then table.remove(idx,i);break end end
    SaveIndex(idx)
end
local function OpSave(name,json,itemCount,mode,password,tag,folder)
    local idx=LoadIndex()
    for _,e in ipairs(idx) do if e.name==name then return false,"Nome já existe!" end end
    if #idx>=MaxSaves() then return false,IsPro() and "Limite atingido" or "Limite de "..CONFIG.FREE_MAX_SAVES.." saves!\n⭐ Ative o Pro." end
    if not pcall(writefile,FOLDER.."/"..name..".json",json) then return false,"Erro ao gravar!" end
    table.insert(idx,1,{name=name,itemCount=itemCount,time=os.time(),mode=mode,size=#json,
        hasPassword=(password and password~="") and true or false,tag=tag or nil,folder=folder or nil,favorite=false})
    SaveIndex(idx); return true
end
local function OpRename(old,new)
    if old==new then return false,"Nome igual!" end
    new=new:gsub('[/\\:*?"<>|]','_')
    local idx=LoadIndex()
    for _,e in ipairs(idx) do if e.name==new then return false,"Nome já existe!" end end
    local op=FOLDER.."/"..old..".json"; local np=FOLDER.."/"..new..".json"
    if not isfile(op) then return false,"Save não encontrado!" end
    local ok,json=pcall(readfile,op)
    if not ok then return false,"Erro ao ler!" end
    pcall(writefile,np,json); pcall(delfile,op)
    for _,e in ipairs(idx) do if e.name==old then e.name=new;break end end
    SaveIndex(idx); return true
end
local function OpDuplicate(name)
    local ok,json=OpLoad(name)
    if not ok then return false,json end
    local newName=name.."_copy"; local counter=1
    local idx=LoadIndex(); local exists={}
    for _,e in ipairs(idx) do exists[e.name]=true end
    while exists[newName] do counter=counter+1;newName=name.."_copy"..counter end
    local dok,data=pcall(function() return HttpService:JSONDecode(json) end)
    return OpSave(newName,json,dok and #(data.Items or {}) or 0,"workspace")
end
local function OpToggleFavorite(name)
    local idx=LoadIndex()
    for _,e in ipairs(idx) do if e.name==name then e.favorite=not e.favorite;break end end
    SaveIndex(idx)
end
local function OpSetTag(name,tagIdx)
    local idx=LoadIndex()
    for _,e in ipairs(idx) do if e.name==name then e.tag=(tagIdx and tagIdx>0) and tagIdx or nil;break end end
    SaveIndex(idx)
end
local function OpSetFolder(name,fn)
    local idx=LoadIndex()
    for _,e in ipairs(idx) do if e.name==name then e.folder=(fn and fn~="") and fn or nil;break end end
    SaveIndex(idx)
end
local function SyncIndex()
    EnsureFolder()
    local idx=LoadIndex(); local synced={}
    for _,e in ipairs(idx) do if isfile(FOLDER.."/"..e.name..".json") then table.insert(synced,e) end end
    local ok,files=pcall(listfiles,FOLDER)
    if ok then
        local indexed={}
        for _,e in ipairs(synced) do indexed[e.name]=true end
        for _,f in ipairs(files) do
            local fname=f:match("([^/\\]+)%.json$")
            if fname and fname~="index" and fname~="history" and fname~="folders" and fname~="logs" and fname~="blocked_keys" and not indexed[fname] then
                local jok,json=pcall(readfile,f)
                if jok and json and json~="" then
                    local dok,data=pcall(function() return HttpService:JSONDecode(json) end)
                    table.insert(synced,{name=fname,itemCount=dok and #(data.Items or {}) or 0,time=dok and (data.Time or 0) or 0,mode="workspace",size=#json})
                end
            end
        end
    end
    SaveIndex(synced); return synced
end
local function SaveBackup(label)
    local fn=BACKUP_FOLDER.."/backup_"..os.time()..".json"
    pcall(writefile,fn,HttpService:JSONEncode({Time=os.time(),Label=label}))
    local ok,files=pcall(listfiles,BACKUP_FOLDER)
    if ok then
        local bf={}
        for _,f in ipairs(files) do if f:match("backup_%d+%.json$") then table.insert(bf,f) end end
        table.sort(bf)
        while #bf>5 do pcall(delfile,bf[1]);table.remove(bf,1) end
    end
end

