local function SyncIndex()
    EnsureFolder();local index=LoadIndex();local synced={}
    for _,e in ipairs(index) do if isfile(FOLDER.."/"..e.name..".json") then table.insert(synced,e) end end
    local ok,files=pcall(listfiles,FOLDER)
    if ok then
        local indexed={};for _,e in ipairs(synced) do indexed[e.name]=true end
        for _,f in ipairs(files) do
            local fname=f:match("([^/\\]+)%.json$")
            if fname and fname~="index" and fname~="history" and fname~="folders" and fname~="stats" and fname~="scripts" and not indexed[fname] then
                local json=SafeRead(f)
                if json and json~="" then
                    local d=SafeJSON(json)
                    table.insert(synced,{name=fname,itemCount=d and #(d.Items or {}) or 0,time=d and (d.Time or 0) or 0,mode="workspace",size=#json,loads=0})
                end
            end
        end
    end
    SaveIndex(synced);return synced
end

local function SaveBackup(label,json)
    BumpStat("totalBackups")
    local data=json or HttpService:JSONEncode({Time=os.time(),Label=label or "backup",Items={}})
    SafeWrite(BACKUP_FOLDER.."/backup_"..os.time()..".json",data)
    local ok,files=pcall(listfiles,BACKUP_FOLDER)
    if ok then
        local bfiles={}
        for _,f in ipairs(files) do if f:match("backup_%d+%.json$") then table.insert(bfiles,f) end end
        table.sort(bfiles)
        while #bfiles>10 do pcall(delfile,bfiles[1]);table.remove(bfiles,1) end
    end
    AddHistory("📸","backup","Backup salvo: "..label)
end

local function GetBackups()
    local ok,files=pcall(listfiles,BACKUP_FOLDER);if not ok then return {} end
    local bfiles={}
    for _,f in ipairs(files) do
        if f:match("backup_%d+%.json$") then
            local ts=tonumber(f:match("backup_(%d+)%.json$")) or 0
            local json=SafeRead(f);local d=json and SafeJSON(json)
            table.insert(bfiles,{path=f,time=ts,label=d and d.Label or "backup",itemCount=d and #(d.Items or {}) or 0,size=json and #json or 0})
        end
    end
    table.sort(bfiles,function(a,b) return a.time>b.time end)
    return bfiles
end

local SUP={Part=true,MeshPart=true,UnionOperation=true,WedgePart=true,CornerWedgePart=true,TrussPart=true,SpawnLocation=true,Model=true,Folder=true,SpecialMesh=true,Script=true,LocalScript=true,ModuleScript=true,StringValue=true,IntValue=true,NumberValue=true,BoolValue=true,Color3Value=true,CFrameValue=true,Vector3Value=true}
local function sCF(cf) return {cf:GetComponents()} end
local function dCF(t)  return CFrame.new(table.unpack(t)) end
local function sC3(c)  return {c.R,c.G,c.B} end
local function dC3(t)  return Color3.new(t[1],t[2],t[3]) end

local function SrInst(inst,d)
    d=d or 0;if d>60 or not SUP[inst.ClassName] then return nil end
    local o={ClassName=inst.ClassName,Name=inst.Name,Props={},Children={}}
    pcall(function()
        local p={}
        if inst:IsA("BasePart") then
            p.Size={inst.Size.X,inst.Size.Y,inst.Size.Z};p.CFrame=sCF(inst.CFrame);p.Color=sC3(inst.Color)
            p.Material=inst.Material.Name;p.Transparency=inst.Transparency;p.Anchored=inst.Anchored
            p.CanCollide=inst.CanCollide;p.CastShadow=inst.CastShadow;p.Locked=inst.Locked
        end
        if inst:IsA("MeshPart") then p.MeshId=inst.MeshId;p.TextureID=inst.TextureID end
        if inst:IsA("Script") or inst:IsA("LocalScript") or inst:IsA("ModuleScript") then p.Source=inst.Source;p.Disabled=inst.Disabled end
        for _,vt in ipairs({"StringValue","IntValue","NumberValue","BoolValue"}) do if inst:IsA(vt) then p.Value=inst.Value end end
        o.Props=p
    end)
    for _,ch in ipairs(inst:GetChildren()) do local s=SrInst(ch,d+1);if s then table.insert(o.Children,s) end end
    return o
end

local function SrWS()
    local r={Items={},Time=os.time()}
